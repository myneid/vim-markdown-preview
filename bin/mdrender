#!/usr/bin/env python3
"""Terminal markdown renderer with ANSI styling."""

import re
import shutil
import subprocess
import sys
import textwrap
from io import StringIO

from markdown_it import MarkdownIt

# ── ANSI primitives ───────────────────────────────────────────────────────────

R  = "\033[0m"   # reset all
B  = "\033[1m"   # bold
DM = "\033[2m"   # dim
IT = "\033[3m"   # italic
UL = "\033[4m"   # underline
ST = "\033[9m"   # strikethrough

def fg(r, g, b): return f"\033[38;2;{r};{g};{b}m"
def bg(r, g, b): return f"\033[48;2;{r};{g};{b}m"

PAL = {
    "h1":     fg(130, 190, 255),  # sky blue
    "h2":     fg( 80, 210, 160),  # mint
    "h3":     fg(255, 200,  80),  # amber
    "h4":     fg(200, 150, 255),  # lavender
    "h5":     fg(255, 140, 120),  # salmon
    "h6":     fg(170, 170, 170),  # gray
    "code_fg":fg(220, 215, 175),
    "code_bg":bg( 30,  30,  40),
    "quote":  fg(140, 140, 155),
    "bar":    fg( 70,  80, 110),
    "link":   fg( 90, 180, 255),
    "hr":     fg( 60,  65,  85),
    "bullet": fg( 90, 200, 255),
    "num":    fg(140, 140, 160),
}

_ANSI_RE = re.compile(r"\033\[[0-9;]*m")

def strip_ansi(s):
    return _ANSI_RE.sub("", s)

# ── ASCII art heading fonts and gradients (compact defaults) ─────────────────

# Keep Rich FIGlet headings intentionally compact to avoid oversized titles.
ASCII_FONTS = {1: "mini", 2: "mini"}

# Maximum rendered Rich FIGlet height (in rows) per heading level.
ASCII_MAX_HEIGHT = {1: 4, 2: 4}

# Each level: (start_rgb, end_rgb)
ASCII_GRADIENTS = {
    1: ((130, 190, 255), ( 80, 140, 255)),  # sky blue  → deep blue
    2: (( 80, 210, 160), ( 40, 180, 120)),  # mint      → teal
}

def _rgb_hex(rgb):
    return f"#{rgb[0]:02x}{rgb[1]:02x}{rgb[2]:02x}"

def _figlet(text, font, c1, c2, width):
    """Render text as ASCII art with Rich Figlet and a vertical colour gradient."""
    try:
        from rich.console import Console
        from rich_pyfiglet import RichFiglet

        buf = StringIO()
        console = Console(
            file=buf,
            force_terminal=True,
            color_system="truecolor",
            width=width,
        )
        fig = RichFiglet(
            text,
            font=font,
            width=width,
            colors=[_rgb_hex(c1), _rgb_hex(c2)],
            horizontal=False,
            remove_blank_lines=True,
        )
        console.print(fig, overflow="ignore", crop=False, end="")
        rendered = buf.getvalue().rstrip("\n")
        return rendered if strip_ansi(rendered).strip() else None
    except Exception as e:
        sys.stderr.write(f"mdrender [rich-figlet]: {type(e).__name__}: {e}\n")
        return None

# ── Inline renderer ───────────────────────────────────────────────────────────

def render_inline(children):
    if not children:
        return ""
    out = []
    for t in children:
        if t.type == "text":
            out.append(t.content)
        elif t.type in ("softbreak", "hardbreak"):
            out.append("\n")
        elif t.type == "code_inline":
            out.append(f"{PAL['code_bg']}{PAL['code_fg']} {t.content} {R}")
        elif t.type == "strong_open":
            out.append(B)
        elif t.type == "strong_close":
            out.append(R)
        elif t.type == "em_open":
            out.append(IT)
        elif t.type == "em_close":
            out.append(R)
        elif t.type == "s_open":
            out.append(ST)
        elif t.type == "s_close":
            out.append(R)
        elif t.type == "link_open":
            out.append(f"{PAL['link']}{UL}")
        elif t.type == "link_close":
            out.append(R)
        elif t.type == "image":
            out.append(f"[{render_inline(t.children)}]")
    return "".join(out)

# ── Word-wrap that preserves ANSI codes ───────────────────────────────────────

def wrap_ansi(styled, width):
    raw = strip_ansi(styled)
    if len(raw) <= width:
        return [styled]

    char_spans = []
    s_i = 0
    for _ in raw:
        while s_i < len(styled):
            m = _ANSI_RE.match(styled, s_i)
            if m:
                s_i = m.end()
            else:
                break
        char_spans.append((s_i, s_i + 1))
        s_i += 1

    raw_lines = textwrap.wrap(raw, width=width) if raw.strip() else [raw]
    result = []
    raw_pos = 0
    for raw_line in raw_lines:
        n = len(raw_line)
        if raw_pos >= len(char_spans):
            break
        s_start = char_spans[raw_pos][0]
        end_pos  = raw_pos + n - 1
        s_end    = char_spans[end_pos][1] if end_pos < len(char_spans) else len(styled)
        while s_end < len(styled) and _ANSI_RE.match(styled, s_end):
            s_end = _ANSI_RE.match(styled, s_end).end()
        result.append(styled[s_start:s_end] + R)
        raw_pos += n
        while raw_pos < len(raw) and raw[raw_pos] == " ":
            raw_pos += 1

    return result if result else [styled]

# ── Block renderer ────────────────────────────────────────────────────────────

class Renderer:
    def __init__(self, width, header_style="ascii"):
        self.width         = width
        self.header_style  = header_style
        self.out           = []
        self.indent        = 0
        self.in_quote      = False
        self.list_stack    = []

    def render(self, tokens):
        i = 0
        while i < len(tokens):
            t = tokens[i]

            if t.type == "heading_open":
                level  = int(t.tag[1])
                inline = tokens[i + 1]
                self._heading(level, render_inline(inline.children))
                i += 3
                continue

            elif t.type == "paragraph_open":
                inline = tokens[i + 1]
                if not self.list_stack:
                    self._paragraph(render_inline(inline.children))
                i += 3
                continue

            elif t.type == "fence":
                self._fence(t.content, t.info.strip())

            elif t.type == "code_block":
                self._fence(t.content, "")

            elif t.type == "hr":
                self._hr()

            elif t.type == "blockquote_open":
                self.in_quote = True

            elif t.type == "blockquote_close":
                self.in_quote = False
                self._emit("\n")

            elif t.type == "bullet_list_open":
                self.list_stack.append(["bullet", 0])
                self.indent += 2

            elif t.type == "bullet_list_close":
                self.list_stack.pop()
                self.indent -= 2
                if not self.list_stack:
                    self._emit("\n")

            elif t.type == "ordered_list_open":
                self.list_stack.append(["ordered", 0])
                self.indent += 2

            elif t.type == "ordered_list_close":
                self.list_stack.pop()
                self.indent -= 2
                if not self.list_stack:
                    self._emit("\n")

            elif t.type == "list_item_open":
                if self.list_stack:
                    self.list_stack[-1][1] += 1
                depth = 1
                j = i + 1
                item_tokens = []
                while j < len(tokens) and depth > 0:
                    if tokens[j].type == "list_item_open":
                        depth += 1
                    elif tokens[j].type == "list_item_close":
                        depth -= 1
                    if depth > 0:
                        item_tokens.append(tokens[j])
                    j += 1
                self._list_item(item_tokens)
                i = j
                continue

            i += 1

        return "".join(self.out)

    # ── headings ──────────────────────────────────────────────────────────────

    def _heading(self, level, styled):
        self._emit("\n")
        if self.header_style == "ascii" and level in ASCII_FONTS:
            self._heading_ascii(level, styled)
        elif level <= 3:
            self._heading_boxed(level, styled)
        else:
            self._heading_plain(level, styled)

    def _heading_ascii(self, level, styled):
        raw  = strip_ansi(styled)
        pad  = " " * self.indent
        avail = self.width - self.indent
        font  = ASCII_FONTS[level]
        c1, c2 = ASCII_GRADIENTS[level]

        art = _figlet(raw, font, c1, c2, avail)
        if art is None or not art.strip():
            self._heading_boxed(level, styled)
            return

        art_lines = art.split("\n")
        art_width = max(len(strip_ansi(l)) for l in art_lines)
        max_height = ASCII_MAX_HEIGHT.get(level, 4)

        # Rich FIGlet can be visually too large even with compact fonts.
        # Fall back to boxed headings when art exceeds width or height limits.
        if art_width > avail or len(art_lines) > max_height:
            self._heading_boxed(level, styled)
            return

        # Separator matches the base color for this level
        color     = PAL.get(f"h{level}", PAL["h6"])
        sep_chars = {1: "═", 2: "─", 3: "╌"}
        sep       = sep_chars.get(level, "─") * art_width

        for line in art_lines:
            self._emit(f"{pad}{line}\n")
        self._emit(f"{pad}{color}{DM}{sep}{R}\n\n")

    def _heading_boxed(self, level, styled):
        color = PAL.get(f"h{level}", PAL["h6"])
        raw   = strip_ansi(styled)
        pad   = " " * self.indent
        inner = len(raw) + 2

        boxes = {
            1: ("╔", "╗", "╚", "╝", "═", "║"),
            2: ("┌", "┐", "└", "┘", "─", "│"),
            3: ("╭", "╮", "╰", "╯", "─", "│"),
        }
        tl, tr, bl, br, h, v = boxes.get(level, boxes[3])
        self._emit(f"{pad}{color}{tl}{h * inner}{tr}{R}\n")
        self._emit(f"{pad}{color}{v}{R} {color}{B}{styled}{R} {color}{v}{R}\n")
        self._emit(f"{pad}{color}{bl}{h * inner}{br}{R}\n\n")

    def _heading_plain(self, level, styled):
        color  = PAL.get(f"h{level}", PAL["h6"])
        pad    = " " * self.indent
        prefix = "#" * level + " "
        self._emit(f"{pad}{color}{B}{prefix}{styled}{R}\n\n")

    # ── other blocks ──────────────────────────────────────────────────────────

    def _paragraph(self, styled):
        avail = self.width - self.indent - (4 if self.in_quote else 0)
        pad   = " " * self.indent
        lines = wrap_ansi(styled, avail)
        if self.in_quote:
            bar = f"{PAL['bar']}│{R} "
            for ln in lines:
                self._emit(f"{pad}{bar}{PAL['quote']}{IT}{ln}{R}\n")
        else:
            for ln in lines:
                self._emit(f"{pad}{ln}\n")
        self._emit("\n")

    def _fence(self, content, lang):
        avail = self.width - self.indent - 2
        pad   = " " * self.indent
        label = f" {lang}" if lang else ""
        self._emit(f"\n{pad}{PAL['code_bg']}{PAL['code_fg']}{B}{label}{R}\n")
        for line in content.rstrip("\n").split("\n"):
            visible = line[:avail]
            fill    = " " * max(0, avail - len(visible))
            self._emit(f"{pad}{PAL['code_bg']}{PAL['code_fg']} {visible}{fill} {R}\n")
        self._emit(f"{pad}{PAL['code_bg']}{PAL['code_fg']} {'─' * avail} {R}\n\n")

    def _hr(self):
        self._emit(f"\n{PAL['hr']}{'─' * self.width}{R}\n\n")

    def _list_item(self, item_tokens):
        kind, n = self.list_stack[-1]
        marker  = (f"{PAL['bullet']}•{R} " if kind == "bullet"
                   else f"{PAL['num']}{n}.{R} ")
        pad   = " " * self.indent
        avail = self.width - self.indent - 4
        for t in item_tokens:
            if t.type == "inline":
                styled = render_inline(t.children)
                lines  = wrap_ansi(styled, avail)
                for idx, ln in enumerate(lines):
                    self._emit(f"{pad}{marker if idx == 0 else '  '}{ln}\n")
                break

    def _emit(self, s):
        self.out.append(s)


# ── entry point ───────────────────────────────────────────────────────────────

def main():
    import argparse
    p = argparse.ArgumentParser()
    p.add_argument("file")
    p.add_argument("--no-pager",      action="store_true")
    p.add_argument("--header-style",  default="ascii", choices=["ascii", "boxed"])
    ns = p.parse_args()

    no_pager     = ns.no_pager
    header_style = ns.header_style
    path         = ns.file
    if not path:
        sys.stderr.write("mdrender: no file specified\n")
        sys.exit(1)

    try:
        source = open(path, encoding="utf-8").read()
    except OSError as e:
        sys.stderr.write(f"mdrender: {e}\n")
        sys.exit(1)

    tokens = MarkdownIt("gfm-like", {"linkify": False}).parse(source)
    width  = min(shutil.get_terminal_size((100, 40)).columns, 100)
    output = Renderer(width, header_style=header_style).render(tokens)

    term_lines = shutil.get_terminal_size((100, 40)).lines
    if not no_pager and sys.stdout.isatty() and output.count("\n") > term_lines - 2:
        pager = subprocess.Popen(["less", "-R", "--mouse", "--wheel-lines=3"], stdin=subprocess.PIPE)
        pager.communicate(output.encode("utf-8"))
    else:
        sys.stdout.write(output)


if __name__ == "__main__":
    main()
